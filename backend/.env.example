# FastAPI / DB
DATABASE_URL=postgresql+psycopg2://app_user:app_password@localhost:5432/app_db
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=86400
REFRESH_TOKEN_EXPIRE_DAYS=60

# CORS
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# SMTP (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-user
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@example.com

# AI providers
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Redis + RQ translation queue
REDIS_URL=redis://localhost:6379/0
TRANSLATE_QUEUE_NAME=translations
TRANSLATE_JOB_MAX_RETRIES=6
TRANSLATE_BACKOFF_SECONDS=5,15,45,120,300,600
TRANSLATE_REPAIR_BATCH_SIZE=500
REDIS_CONNECT_MAX_ATTEMPTS=30
REDIS_CONNECT_RETRY_SECONDS=2

# Optional payment/billing placeholders
BANK_IBAN=YOUR_IBAN_HERE
BANK_ACCOUNT_NAME=YOUR_COMPANY_NAME
